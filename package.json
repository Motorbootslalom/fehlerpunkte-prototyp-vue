{
  "name": "fehlerpunkte-prototyp-vue",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Vue-Portierung des Prototyps für die Eingabemasken der Wettkampfrichter-Fehlerpunktlisten beim Motorbootslalom",
  "scripts": {
    "dev": "npm run config:sync && vite",
    "parcours:build": "node scripts/generate-parcours.ts",
    "build": "npm run config:sync && npm run parcours:build && vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "config:sync": "node scripts/sync-config.ts",
    "config:check": "node scripts/check-config.ts",
    "check": "vue-tsc -b && vitest run && npm run config:check",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "@types/js-yaml": "^4.0.9",
    "html2canvas": "^1.4.1",
    "js-yaml": "^5.2.1",
    "jspdf": "^3.0.1",
    "jspdf-autotable": "^5.0.2",
    "pdfmake": "^0.2.20",
    "qrcode-generator": "^1.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^26.1.1",
    "@types/pdfmake": "^0.2.11",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.1.0",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.0.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
